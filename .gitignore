# --- Claude Code / outils locaux ---
.claude/
CLAUDE.local.md
*.local.json
settings.local.json

# --- Preferences locales (contiennent des chemins specifiques a la machine) ---
preferences.json

# --- Config locale (chemins modeles, reglages perso). On versionne UNIQUEMENT
#     config-sample.txt ; config.txt reste local (copie/edite par l'utilisateur). ---
config.txt

# --- Cloudflare perso (nom de tunnel / domaine). On versionne UNIQUEMENT
#     cloudflare.local.bat.example ; le .bat reel reste local. ---
cloudflare.local.bat

# --- Docs internes / perso (gardes hors du repo, non transmis a GitHub) ---
# Les fichiers vivent un niveau au-dessus (../). Ces patterns evitent une
# re-inclusion accidentelle si un .md interne est recree dans le repo.
PROJECT_BRIEF.md
BRIEF_*.md
PLAN_*.md

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv*/
venv/
env/
.env

# --- Modeles ESRGAN (lourds, a deposer localement) ---
upscale_models/*
!upscale_models/.gitkeep
checkpoints/
loras/
faceswap/
*.pth
*.safetensors
*.onnx
*.pt
*.ckpt
*.onnx
*.bin

# --- Wildcards locaux (set Fooocus, ~218 fichiers). On versionne UNIQUEMENT
#     wildcards/example.txt ; le reste reste local. ---
wildcards/*.txt
!wildcards/example.txt

# --- Presets locaux (referencent tes modeles). On versionne juste l'exemple. ---
presets/*.json
!presets/example.json

# --- Sorties + logs ---
out/
output/
*.tsv

# --- Images de test locales (essais, non versionnees) ---
tests/

# --- Vignettes de styles (samples Fooocus, locales, ~8 Mo, non versionnees) ---
styles/samples/

# --- OS / editeurs ---
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
tags/
